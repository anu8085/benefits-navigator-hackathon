# Copy to .env and fill in real values. .env is git-ignored — never commit it.
# Do NOT paste secrets anywhere other than your local .env.

# --- Databricks workspace / auth ---
DATABRICKS_CONFIG_PROFILE=hackathon-free
DATABRICKS_HOST=https://<workspace-host-without-https>
DATABRICKS_SERVER_HOSTNAME=<workspace-host-without-https>
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_TOKEN=<your_local_databricks_pat>

# --- Unity Catalog source of truth (read-only) ---
UC_CATALOG=benefits_navigator
UC_SCHEMA=trusted
SQL_WAREHOUSE_NAME=Serverless Starter

# --- Anthropic ---
ANTHROPIC_API_KEY=<your_anthropic_api_key>
